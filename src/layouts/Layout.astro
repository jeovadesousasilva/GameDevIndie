---
import { withBase } from '../utils/paths';

interface Props {
	title: string;
	description?: string;
	canonicalPath?: string;
	ogType?: 'website' | 'article';
}

const {
	title,
	description = 'GameDevIndie é a editoria da Midnight Toronto para falar com clareza sobre produção, engines e desenvolvimento de jogos.',
	canonicalPath = 'blog/',
	ogType = 'website'
} = Astro.props;

const faviconHref = withBase('favicon.png');
const homeHref = withBase();
const blogHref = withBase('blog/');
const canonicalUrl = new URL(withBase(canonicalPath), Astro.site).toString();
const socialImage = new URL(withBase('favicon.png'), Astro.site).toString();
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href={faviconHref} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<meta name="google-site-verification" content="pKUvH27rY-k1qWgK6HieRd_swEtUzO55_O2B_w7e_no" />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Jeová de Sousa - Midnight Toronto" />
		<meta name="keywords" content="game dev, desenvolvimento de jogos, engines, mobile, solo dev, midnight toronto, gamedevindie" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:site_name" content="GameDevIndie" />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="site-header">
			<nav class="site-nav">
				<div class="nav-brand">
					<a href={blogHref} class="logo">
						<span class="logo-main">GameDev</span><span class="logo-sub">Indie</span>
					</a>
					<p class="brand-note">Editorial da Midnight Toronto sobre produção, engines e desenvolvimento de jogos.</p>
				</div>
				<div class="nav-links">
					<a href={blogHref}>Blog</a>
					<a href={homeHref}>Midnight Toronto</a>
				</div>
			</nav>
		</header>

		<main class="site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<p class="footer-mark">GameDevIndie</p>
				<p class="footer-copy">Conteúdo editorial da Midnight Toronto sobre engines, produção, mobile e devlog.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f5f1e8;
		--bg-soft: #efe8dc;
		--paper: #fbf8f2;
		--ink: #161718;
		--muted: #655d54;
		--accent: #a14b2d;
		--accent-soft: rgba(161, 75, 45, 0.12);
		--border: rgba(22, 23, 24, 0.12);
		--shadow: 0 16px 40px rgba(51, 34, 18, 0.08);
		--radius-lg: 24px;
		--radius-md: 18px;
		--radius-sm: 999px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Manrope', sans-serif;
		background-color: var(--bg);
		color: var(--ink);
		line-height: 1.6;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		background-image:
			radial-gradient(circle at top left, rgba(161, 75, 45, 0.08), transparent 30%),
			linear-gradient(180deg, #f6f2e8 0%, #f3ede3 100%);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-header {
		padding: 1rem 0;
		border-bottom: 1px solid var(--border);
		background: rgba(251, 248, 242, 0.9);
		backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.site-nav,
	.footer-inner {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 0 1.5rem;
	}

	.nav-brand {
		display: grid;
		gap: 0.25rem;
	}

	.logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.18rem;
		font-weight: 800;
		font-size: 1.35rem;
		letter-spacing: -0.03em;
	}

	.logo-main {
		color: var(--ink);
	}

	.logo-sub {
		color: var(--accent);
	}

	.brand-note {
		font-size: 0.88rem;
		color: var(--muted);
		max-width: 34rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.nav-links a {
		color: var(--muted);
		font-weight: 700;
		font-size: 0.95rem;
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	.site-main {
		flex: 1;
		max-width: 1120px;
		margin: 0 auto;
		padding: 0 1.5rem;
		width: 100%;
	}

	.site-footer {
		border-top: 1px solid var(--border);
		margin-top: 4rem;
		padding: 2.5rem 0;
	}

	.footer-inner {
		align-items: end;
	}

	.footer-mark {
		font-family: 'Instrument Serif', serif;
		font-size: 2rem;
		line-height: 1;
	}

	.footer-copy {
		color: var(--muted);
		font-size: 0.9rem;
		max-width: 30rem;
	}

	h1,
	h2,
	h3 {
		font-family: 'Instrument Serif', serif;
		font-weight: 400;
		line-height: 0.95;
	}

	p {
		margin-bottom: 1.25rem;
		font-size: 1.05rem;
		color: var(--ink);
	}

	ul,
	ol {
		margin-bottom: 1.5rem;
		padding-left: 1.2rem;
	}

	li {
		margin-bottom: 0.75rem;
		color: var(--ink);
	}

	hr {
		border: 0;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}

	blockquote {
		margin: 2rem 0;
		padding: 1.4rem 1.5rem;
		border-left: 3px solid var(--accent);
		background: var(--accent-soft);
		border-radius: 0 14px 14px 0;
	}

	code {
		background: rgba(0, 0, 0, 0.05);
		padding: 0.2rem 0.35rem;
		border-radius: 0.35rem;
		font-size: 0.92em;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}

	pre {
		background: #201c18;
		color: #f6efe4;
		padding: 1.2rem;
		border-radius: 16px;
		overflow-x: auto;
		margin: 1.5rem 0;
		box-shadow: var(--shadow);
	}

	@media (max-width: 600px) {
		.site-header {
			position: static;
		}

		.site-nav,
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
		}

		.nav-links {
			gap: 0.9rem;
		}
	}
</style>
