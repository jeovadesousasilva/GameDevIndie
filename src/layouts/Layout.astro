---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Meu Blog de Game Dev" } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="logo">
					<span class="logo-main">GameDev</span><span class="logo-sub">Indie</span>
				</a>
				<ul class="nav-links">
					<li><a href="/">Início</a></li>
					<li><a href="/blog">Blog</a></li>
					<li><a href="/sobre">Sobre</a></li>
				</ul>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; 2026 GameDev Blog. Criado com Astro.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--bg: #ffffff;
		--text: #111827;
		--primary: #2563eb;
		--secondary: #4b5563;
		--border: #e5e7eb;
		--card-bg: #f9fafb;
	}

	/* Dark mode opcional, mas o foco agora é no fundo claro para leitura */
	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #ffffff; /* Mantendo branco mesmo em dark mode por escolha do usuário para leitura */
			--text: #111827;
			--primary: #2563eb;
			--secondary: #4b5563;
			--border: #e5e7eb;
			--card-bg: #f9fafb;
		}
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
		background-color: var(--bg);
		color: var(--text);
		line-height: 1.6;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	header {
		border-bottom: 1px solid var(--border);
		padding: 1.25rem 0;
		position: sticky;
		top: 0;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(10px);
		z-index: 10;
	}

	nav {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1.5rem;
	}

	.logo {
		font-weight: 800;
		font-size: 1.4rem;
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.logo-main { color: var(--text); }
	.logo-sub { color: var(--primary); }

	.nav-links {
		display: flex;
		list-style: none;
		gap: 2rem;
	}

	nav a {
		text-decoration: none;
		color: var(--secondary);
		font-weight: 500;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	nav a:hover {
		color: var(--primary);
	}

	main {
		flex: 1;
		max-width: 800px;
		margin: 2rem auto;
		padding: 0 1.5rem;
		width: 100%;
	}

	footer {
		border-top: 1px solid var(--border);
		padding: 2rem 0;
		text-align: center;
		color: var(--secondary);
		font-size: 0.9rem;
	}

	/* Markdown Styles (Clean/Docs Style) */
	h1, h2, h3 { margin: 2rem 0 1rem; line-height: 1.3; font-weight: 700; }
	h1 { font-size: 2.5rem; letter-spacing: -0.025em; }
	h2 { font-size: 1.8rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-top: 3rem; }
	h3 { font-size: 1.4rem; }
	p { margin-bottom: 1.25rem; font-size: 1.1rem; color: var(--text); opacity: 0.9; }
	ul, ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
	li { margin-bottom: 0.75rem; font-size: 1.1rem; }
	img { max-width: 100%; height: auto; border-radius: 12px; margin: 2rem 0; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
	hr { border: 0; border-top: 1px solid var(--border); margin: 3rem 0; }
	blockquote { border-left: 4px solid var(--primary); padding: 1rem 1.5rem; margin: 1.5rem 0; background: rgba(37, 99, 235, 0.05); border-radius: 0 8px 8px 0; font-style: italic; }
	code { background: rgba(0,0,0,0.05); padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
	pre { background: #1e293b; color: #f8fafc; padding: 1.5rem; border-radius: 8px; overflow-x: auto; margin: 1.5rem 0; }

	/* Responsividade Adicional */
	@media (max-width: 600px) {
		h1 { font-size: 2rem; }
		nav { flex-direction: column; gap: 1rem; }
	}
</style>
