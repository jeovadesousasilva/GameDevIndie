---
import { withBase } from '../utils/paths';

interface Props {
	locale: 'pt-BR' | 'en';
}

const { locale } = Astro.props;
const isEnglish = locale === 'en';
const siteUrl = 'https://midnighttoronto.com.br';
const pagePath = isEnglish ? 'en/midnight-city/' : 'midnight-city/';
const canonicalUrl = `${siteUrl}${withBase(pagePath)}`;
const ptUrl = `${siteUrl}${withBase('midnight-city/')}`;
const enUrl = `${siteUrl}${withBase('en/midnight-city/')}`;
const homeUrl = withBase(isEnglish ? 'en/' : '');
const faviconHref = withBase('favicon.png');
const studioAsset = withBase('midnight-toronto/assets');
const discordUrl = 'https://discord.gg/6GwbJRFhQU';
const logoImage = `${studioAsset}/images/midnight-city/171-brasil-roleplay-logo-v3.png`;
const socialImage = `${siteUrl}${withBase('midnight-toronto/assets/images/midnight-city/171-brasil-roleplay-logo-v3.png')}`;

const pageContent = {
	'pt-BR': {
		locale: 'pt-BR',
		seo: {
			title: '171 Brasil Roleplay | Servidor SA-MP Mobile em desenvolvimento',
			description:
				'171 Brasil Roleplay é um novo projeto de SA-MP Mobile em desenvolvimento. Entre no Discord para acompanhar a comunidade, votar em ideias e ficar perto das primeiras fases.',
			keywords:
				'171 brasil roleplay, samp mobile, sa-mp mobile, servidor roleplay mobile, discord samp, midnight toronto',
			ogLocale: 'pt_BR'
		},
		backLabel: 'Midnight Toronto',
		topCta: 'Entrar no Discord',
		hero: {
			eyebrow: 'Nova comunidade SA-MP Mobile',
			title: '171 Brasil Roleplay',
			subtitle:
				'Um novo projeto de roleplay mobile em desenvolvimento, com comunidade sendo formada agora antes da abertura oficial.',
			description:
				'Quem entrar no Discord vai entender tudo rápido: a proposta do projeto, as próximas novidades e como acompanhar as primeiras fases mais de perto.',
			primaryCta: 'Entrar no Discord agora',
			secondaryCta: 'Entender o projeto',
			badges: ['Tema claro e direto', 'Comunidade em formação', 'Paleta azul, verde e branco']
		},
		snapshotTitle: 'Em poucos segundos, o que importa saber',
		snapshot: [
			{
				label: 'O que é',
				value: '171 Brasil Roleplay é uma nova comunidade focada em SA-MP Mobile.'
			},
			{
				label: 'Em que fase está',
				value: 'O projeto ainda está em desenvolvimento e reunindo a comunidade inicial.'
			},
			{
				label: 'O que fazer agora',
				value: 'Entrar no Discord para acompanhar as atualizações desde o começo.'
			}
		],
		reasonsTitle: 'Por que entrar agora faz sentido',
		reasonsIntro:
			'Quem chega cedo acompanha a evolução do projeto com mais clareza e participa mais de perto da construção da comunidade.',
		reasons: [
			{
				title: 'Acompanhar as novidades primeiro',
				description:
					'As principais atualizações, anúncios e mudanças de direção vão aparecer primeiro dentro da comunidade.'
			},
			{
				title: 'Participar com opinião real',
				description:
					'Você pode votar em enquetes, sugerir ideias e ajudar a mostrar o que combina com a proposta do servidor.'
			},
			{
				title: 'Ficar perto das primeiras fases',
				description:
					'Quando surgirem novas etapas e testes, o Discord será o caminho mais natural para acompanhar tudo.'
			}
		],
		discordTitle: 'O Discord será o centro da 171 Brasil Roleplay',
		discordIntro:
			'É lá que a comunidade vai crescer nesta fase inicial, com comunicação mais simples, anúncios rápidos e espaço para acompanhar a evolução do projeto.',
		discordPoints: [
			{
				step: '01',
				title: 'Atualizações e anúncios',
				description:
					'Você vê rapidamente o que mudou, o que está sendo preparado e quais serão os próximos passos.'
			},
			{
				step: '02',
				title: 'Enquetes e sugestões',
				description:
					'A comunidade ajuda a apontar preferências, ideias e prioridades para deixar o projeto mais alinhado com o público.'
			},
			{
				step: '03',
				title: 'Mais proximidade com o projeto',
				description:
					'Entrar agora é a forma mais simples de ficar perto da identidade da 171 Brasil Roleplay desde o começo.'
			}
		],
		ctaTitle: 'Se você curte SA-MP Mobile, este é um bom momento para entrar.',
		ctaDescription:
			'Entre no Discord da 171 Brasil Roleplay e acompanhe a comunidade desde o início.',
		ctaButton: 'Participar da comunidade',
		footer: '171 Brasil Roleplay',
		logoAlt: 'Logo da 171 Brasil Roleplay'
	},
	en: {
		locale: 'en',
		seo: {
			title: '171 Brasil Roleplay | SA-MP Mobile project in development',
			description:
				'171 Brasil Roleplay is a new SA-MP Mobile project in development. Join the Discord to follow the community, vote on ideas, and stay close to early phases.',
			keywords:
				'171 brasil roleplay, samp mobile, sa-mp mobile, mobile roleplay server, discord samp, midnight toronto',
			ogLocale: 'en_US'
		},
		backLabel: 'Midnight Toronto',
		topCta: 'Join Discord',
		hero: {
			eyebrow: 'New SA-MP Mobile community',
			title: '171 Brasil Roleplay',
			subtitle:
				'A new mobile roleplay project in development, with its first community being formed before the official opening.',
			description:
				'People who join the Discord will understand the project quickly: the proposal, the next updates, and how to stay closer to the first phases.',
			primaryCta: 'Join Discord now',
			secondaryCta: 'Understand the project',
			badges: ['Clear and welcoming theme', 'Community forming now', 'Blue, green, and white identity']
		},
		snapshotTitle: 'What matters most at a glance',
		snapshot: [
			{
				label: 'What it is',
				value: '171 Brasil Roleplay is a new community focused on SA-MP Mobile.'
			},
			{
				label: 'Current stage',
				value: 'The project is still in development and gathering its first community.'
			},
			{
				label: 'What to do now',
				value: 'Join the Discord to follow updates from the very beginning.'
			}
		],
		reasonsTitle: 'Why joining now makes sense',
		reasonsIntro:
			'People who arrive early can follow the project more clearly and stay closer to the way the community is taking shape.',
		reasons: [
			{
				title: 'See updates first',
				description:
					'The main news, announcements, and direction changes will show up inside the community first.'
			},
			{
				title: 'Take part with real feedback',
				description:
					'You can vote in polls, suggest ideas, and help show what best fits the server vision.'
			},
			{
				title: 'Stay closer to early phases',
				description:
					'When new phases and tests start to appear, Discord will be the easiest place to follow everything.'
			}
		],
		discordTitle: 'Discord will be the center of 171 Brasil Roleplay',
		discordIntro:
			'That is where the community will grow during this early phase, with simple communication, quick updates, and a clear place to follow the project.',
		discordPoints: [
			{
				step: '01',
				title: 'Updates and announcements',
				description:
					'You can quickly see what changed, what is being prepared, and what comes next.'
			},
			{
				step: '02',
				title: 'Polls and suggestions',
				description:
					'The community helps point to preferences, ideas, and priorities so the project feels closer to its audience.'
			},
			{
				step: '03',
				title: 'Closer to the project',
				description:
					'Joining now is the simplest way to stay close to the identity of 171 Brasil Roleplay from the start.'
			}
		],
		ctaTitle: 'If you enjoy SA-MP Mobile, this is a great moment to join.',
		ctaDescription:
			'Join the 171 Brasil Roleplay Discord and follow the community from the beginning.',
		ctaButton: 'Join the community',
		footer: '171 Brasil Roleplay',
		logoAlt: '171 Brasil Roleplay logo'
	}
} as const;

const content = pageContent[locale];
---

<!DOCTYPE html>
<html lang={content.locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{content.seo.title}</title>
		<meta name="description" content={content.seo.description} />
		<meta name="keywords" content={content.seo.keywords} />
		<meta name="author" content="Jeová de Sousa" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="pt-BR" href={ptUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="x-default" href={ptUrl} />
		<link rel="icon" type="image/png" href={faviconHref} />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={content.seo.ogLocale} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={content.seo.title} />
		<meta property="og:description" content={content.seo.description} />
		<meta property="og:image" content={socialImage} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={content.seo.title} />
		<meta property="twitter:description" content={content.seo.description} />
		<meta property="twitter:image" content={socialImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Syne:wght@500;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="mc-page">
			<header class="mc-header">
				<div class="mc-container mc-header-inner">
					<a href={homeUrl} class="mc-brand">
						<div class="mc-brand-logo-shell">
							<img src={logoImage} alt={content.logoAlt} class="mc-brand-logo" />
						</div>
						<div class="mc-brand-copy">
							<span class="mc-brand-name">171 Brasil Roleplay</span>
							<span class="mc-brand-sub">{content.backLabel}</span>
						</div>
					</a>

					<div class="mc-header-actions">
						<a href={homeUrl} class="mc-link-back">{content.backLabel}</a>
						<a href={discordUrl} target="_blank" rel="noreferrer" class="mc-link-discord">
							{content.topCta}
						</a>
					</div>
				</div>
			</header>

			<main>
				<section class="mc-hero">
					<div class="mc-hero-backdrop" aria-hidden="true">
						<img src={logoImage} alt="" class="mc-hero-backdrop-image" />
						<div class="mc-hero-overlay"></div>
					</div>

					<div class="mc-container mc-hero-layout">
						<div class="mc-hero-copy">
							<p class="mc-kicker">{content.hero.eyebrow}</p>
							<h1>{content.hero.title}</h1>
							<p class="mc-hero-subtitle">{content.hero.subtitle}</p>
							<p class="mc-hero-description">{content.hero.description}</p>

							<div class="mc-actions">
								<a
									href={discordUrl}
									target="_blank"
									rel="noreferrer"
									class="mc-btn mc-btn-primary"
								>
									{content.hero.primaryCta}
								</a>
								<a href="#reasons" class="mc-btn mc-btn-secondary">{content.hero.secondaryCta}</a>
							</div>

							<div class="mc-badges">
								{content.hero.badges.map((badge) => (
									<span class="mc-badge">{badge}</span>
								))}
							</div>
						</div>

						<aside class="mc-hero-side">
							<div class="mc-logo-card">
								<img src={logoImage} alt={content.logoAlt} class="mc-hero-logo" />
							</div>

							<div class="mc-snapshot-card">
								<h2>{content.snapshotTitle}</h2>
								<div class="mc-snapshot-list">
									{content.snapshot.map((item) => (
										<div class="mc-snapshot-item">
											<span>{item.label}</span>
											<p>{item.value}</p>
										</div>
									))}
								</div>
							</div>
						</aside>
					</div>
				</section>

				<section id="reasons" class="mc-section">
					<div class="mc-container">
						<div class="mc-section-heading">
							<p class="mc-kicker">171 Brasil Roleplay</p>
							<h2>{content.reasonsTitle}</h2>
							<p>{content.reasonsIntro}</p>
						</div>

						<div class="mc-card-grid">
							{content.reasons.map((reason) => (
								<article class="mc-card">
									<h3>{reason.title}</h3>
									<p>{reason.description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="mc-section mc-section-soft">
					<div class="mc-container">
						<div class="mc-section-heading">
							<p class="mc-kicker">Discord</p>
							<h2>{content.discordTitle}</h2>
							<p>{content.discordIntro}</p>
						</div>

						<div class="mc-card-grid">
							{content.discordPoints.map((item) => (
								<article class="mc-card mc-card-step">
									<span class="mc-step">{item.step}</span>
									<h3>{item.title}</h3>
									<p>{item.description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="mc-section">
					<div class="mc-container">
						<div class="mc-cta-panel">
							<div>
								<p class="mc-kicker">Discord</p>
								<h2>{content.ctaTitle}</h2>
								<p>{content.ctaDescription}</p>
							</div>

							<a
								href={discordUrl}
								target="_blank"
								rel="noreferrer"
								class="mc-btn mc-btn-primary mc-btn-large"
							>
								{content.ctaButton}
							</a>
						</div>
					</div>
				</section>
			</main>

			<footer class="mc-footer">
				<div class="mc-container mc-footer-inner">
					<p>{content.footer} by Midnight Toronto</p>
					<a href={homeUrl}>{content.backLabel}</a>
				</div>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--mc-bg: #eef8f5;
		--mc-bg-soft: #f9fffd;
		--mc-paper: rgba(255, 255, 255, 0.9);
		--mc-paper-strong: rgba(255, 255, 255, 0.96);
		--mc-line: rgba(25, 93, 82, 0.14);
		--mc-text: #0f2230;
		--mc-muted: #3f5e63;
		--mc-accent: #0b61d9;
		--mc-accent-strong: #0a4cb0;
		--mc-accent-alt: #16a34a;
		--mc-shadow: 0 18px 48px rgba(11, 47, 76, 0.14);
		--mc-radius-xl: 36px;
		--mc-radius-lg: 28px;
		--mc-radius-md: 22px;
		--mc-radius-sm: 999px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		min-width: 320px;
		font-family: 'Manrope', sans-serif;
		color: var(--mc-text);
		background:
			radial-gradient(circle at top left, rgba(80, 176, 255, 0.24), transparent 30%),
			radial-gradient(circle at top right, rgba(77, 214, 121, 0.2), transparent 28%),
			linear-gradient(180deg, #f6fffd 0%, #eef8f5 48%, #edf7ff 100%);
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.mc-container {
		width: min(1160px, calc(100% - 40px));
		margin: 0 auto;
	}

	.mc-header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 16px 0;
		background: rgba(249, 255, 253, 0.88);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.55);
	}

	.mc-header-inner,
	.mc-footer-inner,
	.mc-header-actions,
	.mc-brand,
	.mc-actions,
	.mc-badges {
		display: flex;
		align-items: center;
	}

	.mc-header-inner,
	.mc-footer-inner {
		justify-content: space-between;
		gap: 18px;
	}

	.mc-brand {
		gap: 14px;
		min-width: 0;
	}

	.mc-brand-logo-shell {
		width: 58px;
		height: 58px;
		border-radius: 18px;
		background: linear-gradient(135deg, #ffffff 0%, #d8f4e2 100%);
		box-shadow: 0 10px 22px rgba(11, 54, 87, 0.14);
		overflow: hidden;
		flex-shrink: 0;
		border: 1px solid rgba(11, 97, 217, 0.08);
	}

	.mc-brand-logo {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.mc-brand-copy {
		display: grid;
		gap: 2px;
	}

	.mc-brand-name,
	.mc-kicker,
	.mc-step,
	.mc-snapshot-item span {
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.mc-brand-name,
	h1,
	h2,
	h3 {
		font-family: 'Syne', sans-serif;
	}

	.mc-brand-name {
		font-size: 1rem;
	}

	.mc-brand-sub,
	.mc-link-back,
	.mc-footer a,
	.mc-footer p {
		color: var(--mc-muted);
		font-size: 0.92rem;
	}

	.mc-header-actions {
		gap: 12px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.mc-link-back,
	.mc-link-discord,
	.mc-btn,
	.mc-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--mc-radius-sm);
		font-weight: 700;
	}

	.mc-link-back,
	.mc-link-discord {
		min-height: 44px;
		padding: 0 18px;
	}

	.mc-link-back {
		background: rgba(255, 255, 255, 0.74);
		border: 1px solid var(--mc-line);
	}

	.mc-link-discord,
	.mc-btn-primary {
		background: linear-gradient(135deg, #0c66e3 0%, #159947 100%);
		color: #ffffff;
		box-shadow: 0 16px 32px rgba(12, 102, 227, 0.22);
	}

	.mc-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(44px, 7vw, 88px) 0 clamp(52px, 7vw, 80px);
	}

	.mc-hero-backdrop,
	.mc-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.mc-hero-backdrop {
		overflow: hidden;
		background:
			radial-gradient(circle at 20% 16%, rgba(103, 187, 255, 0.3), transparent 26%),
			linear-gradient(135deg, #dff5ff 0%, #edfdf3 52%, #eff7ff 100%);
	}

	.mc-hero-backdrop-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: blur(18px) saturate(0.92) brightness(1.08);
		transform: scale(1.08);
		opacity: 0.22;
	}

	.mc-hero-overlay {
		background:
			linear-gradient(90deg, rgba(248, 255, 254, 0.94) 0%, rgba(248, 255, 254, 0.88) 48%, rgba(248, 255, 254, 0.66) 76%, rgba(248, 255, 254, 0.52) 100%);
	}

	.mc-hero-layout {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
		gap: clamp(24px, 4vw, 42px);
		align-items: start;
	}

	.mc-hero-copy,
	.mc-logo-card,
	.mc-snapshot-card,
	.mc-card,
	.mc-cta-panel {
		border: 1px solid rgba(255, 255, 255, 0.7);
		background: var(--mc-paper);
		backdrop-filter: blur(16px);
		box-shadow: var(--mc-shadow);
	}

	.mc-hero-copy {
		padding: clamp(28px, 5vw, 44px);
		border-radius: var(--mc-radius-xl);
	}

	.mc-kicker,
	.mc-step,
	.mc-snapshot-item span {
		color: var(--mc-accent-strong);
		font-size: 0.78rem;
	}

	h1,
	h2,
	h3 {
		letter-spacing: -0.03em;
		line-height: 0.98;
	}

	h1 {
		max-width: 10ch;
		margin-top: 18px;
		font-size: clamp(3rem, 7vw, 5.5rem);
	}

	h2 {
		font-size: clamp(1.8rem, 3vw, 3rem);
	}

	h3 {
		font-size: clamp(1.35rem, 2vw, 1.85rem);
	}

	p {
		font-size: 1.02rem;
		line-height: 1.7;
		color: var(--mc-muted);
	}

	.mc-hero-subtitle {
		max-width: 56ch;
		margin-top: 20px;
		font-size: clamp(1.1rem, 1.8vw, 1.28rem);
		font-weight: 700;
		color: var(--mc-text);
	}

	.mc-hero-description {
		max-width: 60ch;
		margin-top: 16px;
	}

	.mc-actions,
	.mc-badges {
		flex-wrap: wrap;
		gap: 14px;
	}

	.mc-actions {
		margin-top: 30px;
	}

	.mc-btn {
		min-height: 54px;
		padding: 0 22px;
		border: 1px solid transparent;
		font-weight: 800;
		transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
	}

	.mc-btn-secondary {
		background: rgba(255, 255, 255, 0.82);
		border-color: rgba(11, 97, 217, 0.14);
		color: var(--mc-text);
	}

	.mc-btn:hover,
	.mc-link-discord:hover,
	.mc-link-back:hover {
		transform: translateY(-1px);
	}

	.mc-badges {
		margin-top: 24px;
	}

	.mc-badge {
		min-height: 40px;
		padding: 0 16px;
		background: rgba(255, 255, 255, 0.84);
		border: 1px solid rgba(11, 97, 217, 0.1);
		color: var(--mc-text);
		font-size: 0.9rem;
	}

	.mc-hero-side {
		display: grid;
		gap: 18px;
	}

	.mc-logo-card,
	.mc-snapshot-card,
	.mc-card,
	.mc-cta-panel {
		border-radius: var(--mc-radius-lg);
	}

