---
import { withBase } from '../utils/paths';

interface Props {
	locale: 'pt-BR' | 'en';
}

const { locale } = Astro.props;
const isEnglish = locale === 'en';
const siteUrl = 'https://midnighttoronto.com.br';
const pagePath = isEnglish ? 'en/midnight-city/' : 'midnight-city/';
const canonicalUrl = `${siteUrl}${withBase(pagePath)}`;
const ptUrl = `${siteUrl}${withBase('midnight-city/')}`;
const enUrl = `${siteUrl}${withBase('en/midnight-city/')}`;
const homeUrl = withBase(isEnglish ? 'en/' : '');
const faviconHref = withBase('favicon.png');
const studioAsset = withBase('midnight-toronto/assets');
const discordUrl = 'https://discord.gg/vDkr2wVf6v';
const logoImage = `${studioAsset}/images/midnight-city/midnight-city-logo.png`;
const socialImage = `${siteUrl}${withBase('midnight-toronto/assets/images/midnight-city/midnight-city-logo.png')}`;

const pageContent = {
	'pt-BR': {
		locale: 'pt-BR',
		seo: {
			title: 'Midnight City | Servidor SA-MP Mobile em desenvolvimento',
			description:
				'Midnight City é um novo servidor SA-MP Mobile em desenvolvimento. Entre no Discord para acompanhar o projeto, votar em enquetes e participar da comunidade desde o começo.',
			keywords:
				'midnight city, samp mobile, sa-mp mobile, servidor samp mobile, discord samp, midnight toronto',
			ogLocale: 'pt_BR'
		},
		backLabel: 'Midnight Toronto',
		topCta: 'Entrar no Discord',
		hero: {
			eyebrow: 'Servidor SA-MP Mobile em desenvolvimento',
			title: 'Entre agora no Discord do Midnight City',
			subtitle:
				'A forma mais rápida de entender o projeto é simples: estamos criando um novo servidor SA-MP Mobile e a comunidade já está sendo construída antes da abertura oficial.',
			description:
				'Se você quer acompanhar novidades, sugerir ideias, votar em enquetes e ficar perto dos testes iniciais, o Discord é o lugar certo para entrar agora.',
			primaryCta: 'Quero entrar no Discord',
			secondaryCta: 'Ver por que entrar agora',
			badges: ['Novo servidor SA-MP Mobile', 'Comunidade em formação', 'Convites para testes futuros']
		},
		snapshotTitle: 'Em poucos segundos, o que você precisa saber',
		snapshot: [
			{
				label: 'O que é',
				value: 'Um novo servidor SA-MP Mobile chamado Midnight City.'
			},
			{
				label: 'Em que fase está',
				value: 'Ainda em desenvolvimento, com comunidade sendo montada agora.'
			},
			{
				label: 'Qual é o próximo passo',
				value: 'Entrar no Discord para acompanhar tudo desde o início.'
			}
		],
		reasonsTitle: 'Por que vale a pena entrar agora',
		reasonsIntro:
			'Quem chega cedo entende melhor a proposta do servidor e participa mais de perto das decisões que vão moldar a experiência.',
		reasons: [
			{
				title: 'Acompanhar a criação de perto',
				description:
					'As principais novidades do projeto, ajustes de direção e avanços do servidor vão aparecer primeiro na comunidade.'
			},
			{
				title: 'Participar com opinião real',
				description:
					'Você pode votar em enquetes, sugerir ideias e ajudar a mostrar o que faz sentido para quem realmente quer jogar.'
			},
			{
				title: 'Ficar perto dos primeiros testes',
				description:
					'Quando as fases iniciais abrirem, o Discord será o canal principal para avisos, orientações e convites.'
			}
		],
		discordTitle: 'O Discord será o centro da comunidade',
		discordIntro:
			'É lá que o Midnight City vai crescer nesta fase inicial, com comunicação mais direta e espaço para a comunidade acompanhar a evolução do projeto.',
		discordPoints: [
			{
				step: '01',
				title: 'Atualizações e anúncios',
				description:
					'Você vê as novidades do servidor antes de todo mundo e entende rapidamente o que está sendo feito.'
			},
			{
				step: '02',
				title: 'Enquetes e sugestões',
				description:
					'A comunidade participa do processo com feedback, ideias e decisões guiadas por quem pretende jogar.'
			},
			{
				step: '03',
				title: 'Entrada natural nos testes',
				description:
					'Quem estiver no Discord ficará mais próximo das primeiras oportunidades de testar o servidor.'
			}
		],
		ctaTitle: 'Se você curte SA-MP Mobile, este é o melhor momento para entrar.',
		ctaDescription:
			'Entre no Discord do Midnight City e acompanhe a comunidade desde o começo do projeto.',
		ctaButton: 'Entrar no Discord agora',
		footer: 'Midnight City',
		logoAlt: 'Logo do projeto Midnight City'
	},
	en: {
		locale: 'en',
		seo: {
			title: 'Midnight City | SA-MP Mobile server in development',
			description:
				'Midnight City is a new SA-MP Mobile server in development. Join the Discord to follow the project, vote in polls, and be part of the community from the start.',
			keywords:
				'midnight city, samp mobile, sa-mp mobile, mobile roleplay server, discord samp, midnight toronto',
			ogLocale: 'en_US'
		},
		backLabel: 'Midnight Toronto',
		topCta: 'Join Discord',
		hero: {
			eyebrow: 'SA-MP Mobile server in development',
			title: 'Join the Midnight City Discord now',
			subtitle:
				'The fastest way to understand the project is simple: we are building a new SA-MP Mobile server, and the community is already forming before the official launch.',
			description:
				'If you want to follow updates, suggest ideas, vote in polls, and stay close to early testing, Discord is the right place to join now.',
			primaryCta: 'Join the Discord',
			secondaryCta: 'See why now matters',
			badges: ['New SA-MP Mobile server', 'Community forming now', 'Future testing invites']
		},
		snapshotTitle: 'What you need to understand quickly',
		snapshot: [
			{
				label: 'What it is',
				value: 'A new SA-MP Mobile server called Midnight City.'
			},
			{
				label: 'Current stage',
				value: 'Still in development, with the community being built right now.'
			},
			{
				label: 'Next step',
				value: 'Join the Discord to follow everything from the start.'
			}
		],
		reasonsTitle: 'Why joining now is worth it',
		reasonsIntro:
			'People who join early understand the direction of the server sooner and stay much closer to the decisions that shape the experience.',
		reasons: [
			{
				title: 'Follow the creation closely',
				description:
					'Key updates, direction changes, and server progress will show up in the community first.'
			},
			{
				title: 'Take part with real feedback',
				description:
					'You can vote in polls, share ideas, and help show what makes sense for the people who actually want to play.'
			},
			{
				title: 'Stay near the first tests',
				description:
					'When early phases open, Discord will be the main channel for announcements, guidance, and invitations.'
			}
		],
		discordTitle: 'Discord will be the center of the community',
		discordIntro:
			'That is where Midnight City will grow during this early phase, with direct communication and a clear place for the community to follow the project.',
		discordPoints: [
			{
				step: '01',
				title: 'Updates and announcements',
				description:
					'You will see the latest server news first and understand quickly what is being built.'
			},
			{
				step: '02',
				title: 'Polls and suggestions',
				description:
					'The community helps shape the process with feedback, ideas, and decisions guided by future players.'
			},
			{
				step: '03',
				title: 'A natural path into testing',
				description:
					'Anyone inside the Discord will be closer to the first chances to test the server.'
			}
		],
		ctaTitle: 'If you enjoy SA-MP Mobile, this is the right moment to join.',
		ctaDescription:
			'Join the Midnight City Discord and follow the community from the very beginning of the project.',
		ctaButton: 'Join Discord now',
		footer: 'Midnight City',
		logoAlt: 'Midnight City project logo'
	}
} as const;

const content = pageContent[locale];
---

<!DOCTYPE html>
<html lang={content.locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{content.seo.title}</title>
		<meta name="description" content={content.seo.description} />
		<meta name="keywords" content={content.seo.keywords} />
		<meta name="author" content="Jeová de Sousa" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="pt-BR" href={ptUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="x-default" href={ptUrl} />
		<link rel="icon" type="image/png" href={faviconHref} />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={content.seo.ogLocale} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={content.seo.title} />
		<meta property="og:description" content={content.seo.description} />
		<meta property="og:image" content={socialImage} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={content.seo.title} />
		<meta property="twitter:description" content={content.seo.description} />
		<meta property="twitter:image" content={socialImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Syne:wght@500;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="mc-page">
			<header class="mc-header">
				<div class="mc-container mc-header-inner">
					<a href={homeUrl} class="mc-brand">
						<div class="mc-brand-logo-shell">
							<img src={logoImage} alt={content.logoAlt} class="mc-brand-logo" />
						</div>
						<div class="mc-brand-copy">
							<span class="mc-brand-name">Midnight City</span>
							<span class="mc-brand-sub">{content.backLabel}</span>
						</div>
					</a>

					<div class="mc-header-actions">
						<a href={homeUrl} class="mc-link-back">{content.backLabel}</a>
						<a href={discordUrl} target="_blank" rel="noreferrer" class="mc-link-discord">
							{content.topCta}
						</a>
					</div>
				</div>
			</header>

			<main>
				<section class="mc-hero">
					<div class="mc-hero-backdrop" aria-hidden="true">
						<img src={logoImage} alt="" class="mc-hero-backdrop-image" />
						<div class="mc-hero-overlay"></div>
					</div>

					<div class="mc-container mc-hero-layout">
						<div class="mc-hero-copy">
							<p class="mc-kicker">{content.hero.eyebrow}</p>
							<h1>{content.hero.title}</h1>
							<p class="mc-hero-subtitle">{content.hero.subtitle}</p>
							<p class="mc-hero-description">{content.hero.description}</p>

							<div class="mc-actions">
								<a
									href={discordUrl}
									target="_blank"
									rel="noreferrer"
									class="mc-btn mc-btn-primary"
								>
									{content.hero.primaryCta}
								</a>
								<a href="#reasons" class="mc-btn mc-btn-secondary">{content.hero.secondaryCta}</a>
							</div>

							<div class="mc-badges">
								{content.hero.badges.map((badge) => (
									<span class="mc-badge">{badge}</span>
								))}
							</div>
						</div>

						<aside class="mc-hero-side">
							<div class="mc-logo-card">
								<img src={logoImage} alt={content.logoAlt} class="mc-hero-logo" />
							</div>

							<div class="mc-snapshot-card">
								<h2>{content.snapshotTitle}</h2>
								<div class="mc-snapshot-list">
									{content.snapshot.map((item) => (
										<div class="mc-snapshot-item">
											<span>{item.label}</span>
											<p>{item.value}</p>
										</div>
									))}
								</div>
							</div>
						</aside>
					</div>
				</section>

				<section id="reasons" class="mc-section">
					<div class="mc-container">
						<div class="mc-section-heading">
							<p class="mc-kicker">Midnight City</p>
							<h2>{content.reasonsTitle}</h2>
							<p>{content.reasonsIntro}</p>
						</div>

						<div class="mc-card-grid">
							{content.reasons.map((reason) => (
								<article class="mc-card">
									<h3>{reason.title}</h3>
									<p>{reason.description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="mc-section mc-section-soft">
					<div class="mc-container">
						<div class="mc-section-heading">
							<p class="mc-kicker">Discord</p>
							<h2>{content.discordTitle}</h2>
							<p>{content.discordIntro}</p>
						</div>

						<div class="mc-card-grid">
							{content.discordPoints.map((item) => (
								<article class="mc-card mc-card-step">
									<span class="mc-step">{item.step}</span>
									<h3>{item.title}</h3>
									<p>{item.description}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="mc-section">
					<div class="mc-container">
						<div class="mc-cta-panel">
							<div>
								<p class="mc-kicker">Discord</p>
								<h2>{content.ctaTitle}</h2>
								<p>{content.ctaDescription}</p>
							</div>

							<a
								href={discordUrl}
								target="_blank"
								rel="noreferrer"
								class="mc-btn mc-btn-primary mc-btn-large"
							>
								{content.ctaButton}
							</a>
						</div>
					</div>
				</section>
			</main>

			<footer class="mc-footer">
				<div class="mc-container mc-footer-inner">
					<p>{content.footer} by Midnight Toronto</p>
					<a href={homeUrl}>{content.backLabel}</a>
				</div>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--mc-bg: #f5efe7;
		--mc-bg-soft: #fff8ef;
		--mc-paper: rgba(255, 249, 241, 0.9);
		--mc-paper-strong: rgba(255, 249, 241, 0.96);
		--mc-line: rgba(117, 83, 54, 0.16);
		--mc-text: #191715;
		--mc-muted: #5e5148;
		--mc-accent: #d84f25;
		--mc-accent-strong: #b33c18;
		--mc-shadow: 0 18px 48px rgba(34, 23, 16, 0.14);
		--mc-radius-xl: 36px;
		--mc-radius-lg: 28px;
		--mc-radius-md: 22px;
		--mc-radius-sm: 999px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		min-width: 320px;
		font-family: 'Manrope', sans-serif;
		color: var(--mc-text);
		background:
			radial-gradient(circle at top left, rgba(255, 214, 176, 0.6), transparent 30%),
			radial-gradient(circle at top right, rgba(255, 233, 209, 0.5), transparent 28%),
			linear-gradient(180deg, #fff8ef 0%, #f8f1e6 48%, #f6efe6 100%);
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.mc-container {
		width: min(1160px, calc(100% - 40px));
		margin: 0 auto;
	}

	.mc-header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 16px 0;
		background: rgba(255, 248, 239, 0.88);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.45);
	}

	.mc-header-inner,
	.mc-footer-inner,
	.mc-header-actions,
	.mc-brand,
	.mc-actions,
	.mc-badges {
		display: flex;
		align-items: center;
	}

	.mc-header-inner,
	.mc-footer-inner {
		justify-content: space-between;
		gap: 18px;
	}

	.mc-brand {
		gap: 14px;
		min-width: 0;
	}

	.mc-brand-logo-shell {
		width: 58px;
		height: 58px;
		border-radius: 18px;
		background: #0f1117;
		box-shadow: 0 10px 22px rgba(16, 14, 13, 0.18);
		overflow: hidden;
		flex-shrink: 0;
	}

	.mc-brand-logo {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.mc-brand-copy {
		display: grid;
		gap: 2px;
	}

	.mc-brand-name,
	.mc-kicker,
	.mc-step,
	.mc-snapshot-item span {
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.mc-brand-name,
	h1,
	h2,
	h3 {
		font-family: 'Syne', sans-serif;
	}

	.mc-brand-name {
		font-size: 1rem;
	}

	.mc-brand-sub,
	.mc-link-back,
	.mc-footer a,
	.mc-footer p {
		color: var(--mc-muted);
		font-size: 0.92rem;
	}

	.mc-header-actions {
		gap: 12px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.mc-link-back,
	.mc-link-discord,
	.mc-btn,
	.mc-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--mc-radius-sm);
		font-weight: 700;
	}

	.mc-link-back,
	.mc-link-discord {
		min-height: 44px;
		padding: 0 18px;
	}

	.mc-link-back {
		background: rgba(255, 255, 255, 0.52);
		border: 1px solid var(--mc-line);
	}

	.mc-link-discord,
	.mc-btn-primary {
		background: linear-gradient(135deg, #eb5b2a 0%, #c43f18 100%);
		color: #fffaf6;
		box-shadow: 0 16px 32px rgba(196, 63, 24, 0.24);
	}

	.mc-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(44px, 7vw, 88px) 0 clamp(52px, 7vw, 80px);
	}

	.mc-hero-backdrop,
	.mc-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.mc-hero-backdrop {
		overflow: hidden;
		background:
			radial-gradient(circle at 18% 18%, rgba(255, 181, 96, 0.22), transparent 24%),
			linear-gradient(135deg, #161116 0%, #1f1717 50%, #1a1111 100%);
	}

	.mc-hero-backdrop-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: blur(18px) saturate(0.88) brightness(0.42);
		transform: scale(1.08);
		opacity: 0.52;
	}

	.mc-hero-overlay {
		background:
			linear-gradient(90deg, rgba(255, 248, 239, 0.94) 0%, rgba(255, 248, 239, 0.84) 44%, rgba(255, 248, 239, 0.55) 72%, rgba(20, 14, 14, 0.16) 100%);
	}

	.mc-hero-layout {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
		gap: clamp(24px, 4vw, 42px);
		align-items: start;
	}

	.mc-hero-copy,
	.mc-logo-card,
	.mc-snapshot-card,
	.mc-card,
	.mc-cta-panel {
		border: 1px solid rgba(255, 255, 255, 0.5);
		background: var(--mc-paper);
		backdrop-filter: blur(16px);
		box-shadow: var(--mc-shadow);
	}

	.mc-hero-copy {
		padding: clamp(28px, 5vw, 44px);
		border-radius: var(--mc-radius-xl);
	}

	.mc-kicker,
	.mc-step,
	.mc-snapshot-item span {
		color: var(--mc-accent-strong);
		font-size: 0.78rem;
	}

	h1,
	h2,
	h3 {
		letter-spacing: -0.03em;
		line-height: 0.98;
	}

	h1 {
		max-width: 10ch;
		margin-top: 18px;
		font-size: clamp(3rem, 7vw, 5.5rem);
	}

	h2 {
		font-size: clamp(1.8rem, 3vw, 3rem);
	}

	h3 {
		font-size: clamp(1.35rem, 2vw, 1.85rem);
	}

	p {
		font-size: 1.02rem;
		line-height: 1.7;
		color: var(--mc-muted);
	}

	.mc-hero-subtitle {
		max-width: 56ch;
		margin-top: 20px;
		font-size: clamp(1.1rem, 1.8vw, 1.28rem);
		font-weight: 700;
		color: var(--mc-text);
	}

	.mc-hero-description {
		max-width: 60ch;
		margin-top: 16px;
	}

	.mc-actions,
	.mc-badges {
		flex-wrap: wrap;
		gap: 14px;
	}

	.mc-actions {
		margin-top: 30px;
	}

	.mc-btn {
		min-height: 54px;
		padding: 0 22px;
		border: 1px solid transparent;
		font-weight: 800;
		transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
	}

	.mc-btn-secondary {
		background: rgba(255, 255, 255, 0.52);
		border-color: var(--mc-line);
		color: var(--mc-text);
	}

	.mc-btn:hover,
	.mc-link-discord:hover,
	.mc-link-back:hover {
		transform: translateY(-1px);
	}

	.mc-badges {
		margin-top: 24px;
	}

	.mc-badge {
		min-height: 40px;
		padding: 0 16px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid rgba(255, 255, 255, 0.6);
		color: var(--mc-text);
		font-size: 0.9rem;
	}

	.mc-hero-side {
		display: grid;
		gap: 18px;
	}

	.mc-logo-card,
	.mc-snapshot-card,
	.mc-card,
	.mc-cta-panel {
		border-radius: var(--mc-radius-lg);
	}

	.mc-logo-card {
		padding: 18px;
		background: rgba(16, 17, 23, 0.88);
	}

	.mc-hero-logo {
		width: 100%;
		border-radius: 22px;
	}

