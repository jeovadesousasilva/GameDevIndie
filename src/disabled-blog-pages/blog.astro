---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/paths';
import { getAllPosts, getFeaturedPost } from '../utils/blog';

const posts = getAllPosts();
const featuredPost = getFeaturedPost(posts);

function formatDate(date: string) {
	return new Intl.DateTimeFormat('pt-BR', {
		day: '2-digit',
		month: 'long',
		year: 'numeric',
		timeZone: 'UTC'
	}).format(new Date(date));
}
---

<Layout
	title="GameDevIndie | Blog de desenvolvimento de jogos da Midnight Toronto"
	description="Guias práticos, decisões de produção, engines, mobile e bastidores de quem está construindo jogos indie de verdade."
	canonicalPath="blog/"
>
	<section class="blog-hero">
		<div class="hero-copy">
			<p class="eyebrow">GameDevIndie</p>
			<h1>Um blog sobre fazer jogos com escopo real, clareza técnica e menos ruído.</h1>
			<p class="hero-text">
				Conteúdo editorial da Midnight Toronto para falar sobre engines, produção, mobile e decisões que
				importam para quem desenvolve sozinho ou em times pequenos.
			</p>
		</div>
		<div class="hero-note">
			<span>Foco editorial</span>
			<ul>
				<li>Engines e escolhas de produção</li>
				<li>Desenvolvimento solo com visão prática</li>
				<li>Mobile, escopo e bastidores do estúdio</li>
			</ul>
		</div>
	</section>

	{featuredPost && (
		<section class="featured-section">
			<div class="section-heading">
				<p class="section-label">Artigo em destaque</p>
				<h2>Comece por aqui</h2>
			</div>

			<article class="featured-card">
				<div class="featured-meta">
					<span>{featuredPost.category}</span>
					<span>{formatDate(featuredPost.pubDate)}</span>
					<span>{featuredPost.readingTime}</span>
				</div>
				<h3>
					<a href={withBase(`blog/${featuredPost.slug}/`)}>{featuredPost.title}</a>
				</h3>
				<p>{featuredPost.description}</p>
				<div class="featured-actions">
					<a href={withBase(`blog/${featuredPost.slug}/`)} class="read-link">Ler artigo</a>
					<div class="tag-row">
						{featuredPost.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</div>
			</article>
		</section>
	)}

	<section class="archive-section">
		<div class="section-heading">
			<p class="section-label">Arquivo editorial</p>
			<h2>Todos os textos</h2>
		</div>

		<div class="archive-list">
			{posts.map((post) => (
				<article class="archive-item">
					<div class="archive-meta">
						<span>{post.category}</span>
						<span>{formatDate(post.pubDate)}</span>
						<span>{post.readingTime}</span>
					</div>
					<div class="archive-copy">
						<h3><a href={withBase(`blog/${post.slug}/`)}>{post.title}</a></h3>
						<p>{post.description}</p>
					</div>
					<a href={withBase(`blog/${post.slug}/`)} class="archive-link">Abrir</a>
				</article>
			))}

			<div class="archive-placeholder">
				<p>Novos textos sobre produção, mobile e devlog entram aqui conforme o estúdio evolui.</p>
			</div>
		</div>
	</section>
</Layout>

<style>
	.blog-hero,
	.featured-section,
	.archive-section {
		padding-top: 3rem;
	}

	.blog-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.75fr);
		gap: 2rem;
		align-items: start;
		padding-top: 4rem;
	}

	.eyebrow,
	.section-label {
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.blog-hero h1,
	.section-heading h2,
	.featured-card h3,
	.archive-copy h3 {
		font-size: clamp(2.8rem, 6vw, 5rem);
		margin-top: 0.75rem;
	}

	.hero-text {
		max-width: 48rem;
		margin-top: 1.25rem;
		font-size: 1.12rem;
		color: var(--muted);
	}

	.hero-note,
	.featured-card,
	.archive-item,
	.archive-placeholder {
		background: var(--paper);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
	}

	.hero-note {
		padding: 1.5rem;
	}

	.hero-note span {
		display: block;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.hero-note ul {
		margin-top: 1rem;
		padding-left: 1rem;
	}

	.hero-note li {
		color: var(--muted);
	}

	.section-heading {
		display: grid;
		gap: 0.35rem;
		margin-bottom: 1.5rem;
	}

	.section-heading h2 {
		font-size: clamp(2.2rem, 4vw, 3.4rem);
	}

	.featured-card {
		padding: 2rem;
	}

	.featured-meta,
	.archive-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
	}

	.featured-card h3 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin-top: 1rem;
	}

	.featured-card h3 a:hover,
	.archive-copy h3 a:hover {
		color: var(--accent);
	}

	.featured-card p {
		max-width: 46rem;
		margin-top: 1rem;
		color: var(--muted);
		font-size: 1.05rem;
	}

	.featured-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
		justify-content: space-between;
		margin-top: 1.5rem;
	}

	.read-link,
	.archive-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border-radius: var(--radius-sm);
		background: var(--accent);
		color: #fff8f2;
		font-weight: 800;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		min-height: 34px;
		padding: 0 0.85rem;
		border-radius: var(--radius-sm);
		background: var(--bg-soft);
		color: var(--muted);
		font-size: 0.85rem;
		font-weight: 700;
	}

	.archive-list {
		display: grid;
		gap: 1rem;
	}

	.archive-item {
		display: grid;
		grid-template-columns: 170px minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: start;
		padding: 1.5rem;
	}

	.archive-copy h3 {
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		margin-top: 0;
	}

	.archive-copy p {
		margin-top: 0.75rem;
		color: var(--muted);
	}

	.archive-placeholder {
		padding: 1.5rem;
		color: var(--muted);
	}

	@media (max-width: 800px) {
		.blog-hero,
		.archive-item {
			grid-template-columns: 1fr;
		}

		.archive-link {
			width: fit-content;
		}
	}
</style>
